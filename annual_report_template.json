{
  "_template_instructions": {
    "how_to_use": [
      "1. Find every value that starts with << and ends with >>",
      "2. Replace it with your actual company data",
      "3. Remove any section blocks you don't need (delete the {} object)",
      "4. Duplicate any section block you need more of (copy-paste the {} object)",
      "5. Delete this _template_instructions key before generating the docx",
      "6. Run: npx ts-node src/index.ts data/your_report.json output/report.docx"
    ],
    "placeholder_guide": {
      "<<TEXT>>": "Replace with a plain string",
      "<<NUMBER>>": "Replace with a number (no quotes)",
      "<<HEX_COLOR>>": "Replace with 6-digit hex color without # e.g. 003087",
      "<<FILENAME>>": "Replace with image filename in your data/ folder e.g. logo.png",
      "<<YEAR>>": "Replace with fiscal year string e.g. 2024-25",
      "<<REMOVE_IF_UNUSED>>": "Delete this entire section block if not applicable"
    },
    "section_type_reference": {
      "text": "Heading + body paragraphs + optional pull quote",
      "richText": "Paragraphs with inline bold numbers/stats",
      "textTwoColumn": "Two-column layout with subsections and optional pull quote",
      "kpi": "Metric cards (value + delta + label)",
      "chart": "Bar / line / pie / doughnut chart",
      "table": "Data table with headers and rows",
      "financials": "Income statement / balance sheet style with bold totals",
      "bullets": "Ordered or unordered list",
      "quote": "Pull quote with attribution",
      "signature": "Closing block with name and role",
      "team": "Grid of people with name, role, tenure",
      "timeline": "Year-by-year milestones",
      "twoColumn": "Two columns each with separate heading + body",
      "awards": "Awards grid (title, body, year)",
      "comparison": "Feature matrix / competitor comparison table",
      "image": "Embedded image with caption",
      "divider": "Horizontal rule / section separator",
      "pageBreak": "Force next content to start on a new page"
    }
